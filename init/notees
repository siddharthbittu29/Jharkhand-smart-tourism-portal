// init/views/places/index.ejs
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Explore Jharkhand</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar">
    <a href="/" class="brand">JK Tourism</a>
    <div class="nav-links">
      <a href="/places">Explore Places</a>
      <a href="/listings">Listings</a>
    </div>
  </nav>

  <div class="container">
    <!-- Page Content -->
    <h1>Explore Jharkhand</h1>

    <form class="filters" method="get" action="/places">
      <input type="text" name="q" value="<%= query.q %>" placeholder="Search places..." />

      <select name="district">
        <option value="">All Districts</option>
        <% ['Ranchi', 'Latehar', 'Hazaribagh', 'Deoghar', 'Giridih'].forEach(d => { %>
          <option value="<%= d %>" <%= query.district === d ? 'selected' : '' %>><%= d %></option>
        <% }) %>
      </select>

      <select name="category">
        <option value="">All Categories</option>
        <% ['Waterfall', 'National Park', 'Temple', 'Heritage', 'Viewpoint'].forEach(c => { %>
          <option value="<%= c %>" <%= query.category === c ? 'selected' : '' %>><%= c %></option>
        <% }) %>
      </select>

      <select name="ecoMin">
        <option value="">Eco Score</option>
        <% [50, 60, 70, 80, 90].forEach(s => { %>
          <option value="<%= s %>" <%= String(query.ecoMin) === String(s) ? 'selected' : '' %>>≥ <%= s %></option>
        <% }) %>
      </select>

      <button class="btn" type="submit">Apply</button>
      <a class="btn" href="/places">Clear</a>
    </form>

    <p class="muted" style="margin:6px 0;"><%= places.length %> result(s)</p>

    <div class="grid">
      <% places.forEach(p => { %>
        <a class="card" href="/places/<%= p._id %>">
          <img src="<%= p.image || 'https://placehold.co/600x400' %>" alt="<%= p.name %>">
          <div class="card-body">
            <h3><%= p.name %></h3>
            <p><%= p.district %> • <%= p.category %></p>
            <p class="muted">Eco Score: <strong><%= p.eco?.ecoScore %></strong></p>
            <div>
              <% (p.tags || []).slice(0, 3).forEach(t => { %>
                <span class="eco-tag"><%= t %></span>
              <% }) %>
            </div>
          </div>
        </a>
      <% }) %>
      <% if (!places.length) { %>
        <p>No results. Try clearing filters.</p>
      <% } %>
    </div>
  </div>

  <!-- Footer -->
  <footer>
    <p>&copy; 2025 JK Tourism. All Rights Reserved.</p>
  </footer>
</body>
</html>






// init/views/places/show.ejs
<a href="/places">← Back</a>
<article class="detail">
  <img src="<%= place.image || 'https://placehold.co/800x500' %>" alt="<%= place.name %>">
  <div>
    <h1><%= place.name %></h1>
    <p class="muted"><%= place.district %> • <%= place.category %> • Eco Score <strong><%= place.eco?.ecoScore %></strong></p>
    <p><%= place.description %></p>

    <% if (place.eco?.guidelines?.length) { %>
      <h3>Responsible Travel</h3>
      <ul>
        <% place.eco.guidelines.forEach(g => { %>
          <li><%= g %></li>
        <% }) %>
      </ul>
    <% } %>

    <div class="actions">
      <% if (place.contact?.whatsapp) { %>
        <a class="btn" href="https://wa.me/<%= place.contact.whatsapp.replace(/\D/g,'') %>?text=Hi!%20I%20want%20to%20know%20more%20about%20<%= encodeURIComponent(place.name) %>" target="_blank">Enquire on WhatsApp</a>
      <% } %>
      <% if (place.contact?.website) { %>
        <a class="btn" href="<%= place.contact.website %>" target="_blank">Official Site</a>
      <% } %>
    </div>

    <h3>Good to Know</h3>
    <ul>
      <% if (place.bestSeason?.length) { %><li><strong>Best Season:</strong> <%= place.bestSeason.join(', ') %></li><% } %>
      <% if (place.timeRequiredHrs) { %><li><strong>Time Required:</strong> <%= place.timeRequiredHrs %> hrs</li><% } %>
      <% if (place.entryFeeINR) { %><li><strong>Entry Fee:</strong> ₹<%= place.entryFeeINR %></li><% } %>
      <li><strong>Accessibility:</strong> Wheelchair <%= place.accessibility?.wheelchair? '✔':'✘' %>, Public Transport <%= place.accessibility?.publicTransport? '✔':'✘' %></li>
    </ul>
  </div>
</article>
