
// init/models/place.js -------------------------------------------\\
const mongoose = require('mongoose');

const ecoSchema = new mongoose.Schema({
  ecoScore: { type: Number, min: 0, max: 100, required: true },
  litterIndex: { type: Number, min: 0, max: 100, default: 0 },
  communityOwned: { type: Boolean, default: false },
  guidelines: [{ type: String }]
}, { _id: false });

const placeSchema = new mongoose.Schema({
  name: { type: String, required: true, trim: true },
  district: { type: String, required: true, trim: true },
  category: {
    type: String,
    enum: [
      'Waterfall','National Park','Temple','Heritage','Viewpoint',
      'Lake','Museum','Festival','City','Other'
    ],
    default: 'Other'
  },
  description: { type: String, trim: true },
  image: { type: String, trim: true },
  tags: [{ type: String, trim: true }],
  bestSeason: [{ type: String, trim: true }],
  difficulty: { type: String, enum: ['Easy','Moderate','Hard'], default: 'Easy' },
  timeRequiredHrs: { type: Number, min: 0 },
  entryFeeINR: { type: Number, min: 0 },
  eco: { type: ecoSchema, required: true }
}, { timestamps: true });




module.exports = mongoose.model('Place', placeSchema);




// init/routes/places.js -------------------------------------------\\
const express = require('express');
// const router = express.Router();
const Place = require('../models/place');

// Route to display places with filters
router.get('/', async (req, res, next) => {
  try {
    const { q, district, category, ecoMin, tag } = req.query;
    const filter = {};

    // Build query filters
    if (q && q.trim()) {
      const rx = new RegExp(q.trim(), 'i');
      filter.$or = [
        { name: rx },
        { district: rx },
        { category: rx },
        { tags: rx },
        { description: rx }
      ];
    }

    if (district) filter.district = district;
    if (category) filter.category = category;
    if (tag) filter.tags = tag;
    if (ecoMin) filter['eco.ecoScore'] = { $gte: Number(ecoMin) };

    // Get filtered places
    const places = await Place.find(filter).sort({ 'eco.ecoScore': -1, createdAt: -1 });

    // Pass places data to the view
    res.render('places/index', { places, query: req.query });
  } catch (e) {
    next(e);
  }
});

module.exports = router;






