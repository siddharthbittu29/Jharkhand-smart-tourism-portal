 <%
/* Safe defaults so EJS never throws ReferenceError when t/lang are missing */
var t = (typeof t !== 'undefined' && t) || {
  sitemap: "Sitemap",
  skip: "Skip To Main Content",
  access: "Accessibility",
  about: "About Us",
  contact: "Contact Us",
  reservations: "JTDC Reservations",
  helpline: "Tourism Helpline"
};
var lang = (typeof lang !== 'undefined' && lang) || 'en';
%>
 <!DOCTYPE html>
<html lang="en">
<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jharkhand Tourism Development Corporation</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/home.css">
  <link
rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <style>
    body { font-family: "Segoe UI", Arial, sans-serif; background-color:#F5F0E1; }
    .top-bar { background-color: #004d40; color: #fff; font-size: 14px; padding: 5px 0; }
    .top-bar a { color: #ffeb3b; text-decoration: none; margin-left: 10px; }
    .navbar { background-color: #00695c; }
    .navbar-brand img { height: 55px; }
    .announcement { background-color: #fff3cd; color: #333; padding: 8px 10px; font-size: 14px; overflow: hidden; white-space: nowrap; }
    .announcement span { display: inline-block; padding-left: 100%; animation: scroll 35s linear infinite; }
    @keyframes scroll { 0% { transform: translateX(0%); } 100% { transform: translateX(-100%); } }
    .section-title { color: #004d40; margin-top: 40px; margin-bottom: 25px; text-align: center; text-transform: uppercase; font-weight: 600; }
    .tour-card img { height: 220px; object-fit: cover; }
    .tour-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .tour-card:hover { transform: scale(1.03); box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2); }
    footer { background-color: #004d40; color: #fff; padding: 25px 0; font-size: 14px; }
    footer a { color: #ffeb3b; text-decoration: none; }
    .cta-row { display:flex; gap:12px; justify-content:center; margin: 10px 0 30px; }
  </style>
</head>
<body>

 <!-- 🔝 Top Bar (resilient to missing t/lang) -->
<div class="top-bar text-center px-2">
  <a href="/sitemap.xml"><%= (t && t.sitemap) || "Sitemap" %></a> |
  <a href="#main"><%= (t && t.skip) || "Skip To Main Content" %></a> |

  <form action="/lang" method="POST" style="display:inline;">
    <select name="lang" onchange="this.form.submit()">
      <option value="en" <%= (lang==='en') ? 'selected' : '' %>>English</option>
      <option value="hi" <%= (lang==='hi') ? 'selected' : '' %>>हिन्दी</option>
    </select>
  </form>

  &nbsp; | <%= (t && t.reservations) || "JTDC Reservations" %>:
  <a href="tel:06512438866">0651-2438866</a> / <a href="tel:2438002">2438002</a> |
  <%= (t && t.helpline) || "Tourism Helpline" %>: <a href="tel:1364">1364</a>

  <span class="float-end me-3">
    <a href="/accessibility"><%= (t && t.access) || "Accessibility" %></a> -
    <a href="/about"><%= (t && t.about) || "About Us" %></a> -
    <a href="/contact"><%= (t && t.contact) || "Contact Us" %></a>
  </span>
</div>

  <!-- 📢 Announcements -->
  <div class="announcement">
    <span>
      📢 Circular - Updated Tariff for JTDC Hotels | Tender - Eco Resort at Netarhat | 
      Jharkhand Monsoon on a Plate | Patratu Valley Ropeway Project | 
      Jharkhand – India’s Green Tourism Pioneer | Trek to Lodh Falls - Winter 2025
    </span>
  </div>

  <!-- <div class="d-flex gap-3 justify-content-center mt-4">
  <a href="/places" class="home-btn">Explore Places</a>
  <a href="/listings" class="home-btn">View Listings</a>

</div> -->

 <!-- 🏞️ Discover Jharkhand Section -->
    <section class="container py-5 text-center hero-section">

  <div class="hero-overlay">

    <h1 class="fw-bold display-4 text-white">
      Smart Tourism Portal of Jharkhand
    </h1>

    <p class="lead text-white mb-5">
      Discover waterfalls, wildlife, temples, festivals and AI-powered travel experiences.
    </p>
    <div class="hero-search mt-4">

    <input

        id="globalSearch"

        type="text"

        class="form-control"

        placeholder="🔍 Search places, hotels, waterfalls, wildlife..."

    >

    <div id="searchSuggestions"></div>

</div>

  </div>

  <!-- AI SMART PLANNER -->
  <div class="ai-planner-card">

    <h2>🤖 AI Smart Trip Planner</h2>

    <p>
      Plan your Jharkhand journey instantly
    </p>

    <form action="/planner" method="POST">

      <div class="row g-3">

        <div class="col-md-5">
        <input
            type="text"
            class="form-control"
            name="destination"
            placeholder="Family trip to waterfalls"
            required
          >
        </div>

        <div class="col-md-2">
          <input
            type="number"
            class="form-control"
            name="days"
            min="1"
            max="15"
            placeholder="Days"
            required
          >
        </div>

        <div class="col-md-3">
          <input
            type="number"
            class="form-control"
            name="budget"
            placeholder="Budget ₹"
            required
          >
        </div>

        <div class="col-md-2">
          <button
            type="submit"
            class="btn btn-success w-100"
          >
            Generate
          </button>
        </div>

      </div>

    </form>

  </div>

  <div class="mt-4">
    <a href="/smart-tourism" class="btn btn-lg btn-primary smart-cta">
      Explore Smart Tourism
    </a>
  </div>

</section>
<!-- ===================================== -->
<!-- SMART TOURISM DASHBOARD -->
<!-- ===================================== -->

<section class="container my-5">

    <div class="row g-4">

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <div class="dashboard-icon">📍</div>

                <h2>250+</h2>

                <p>Tourist Places</p>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <div class="dashboard-icon">🏨</div>

                <h2>120+</h2>

                <p>Hotels</p>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <div class="dashboard-icon">🤖</div>

                <h2>AI</h2>

                <p>Trip Planner</p>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="dashboard-card">

                <div class="dashboard-icon">🌿</div>

                <h2>Eco</h2>

                <p>Smart Tourism</p>

            </div>

        </div>

    </div>

</section>
<!-- ====================================== -->
<!-- FEATURED EXPERIENCES -->
<!-- ====================================== -->

<section class="container my-5">

    <div class="text-center mb-5">

        <h2 class="section-title">

            Experience Jharkhand

        </h2>

        <p class="text-muted">

            Explore the best experiences curated for every traveler.

        </p>

    </div>

    <div class="row g-4">

        <div class="col-lg-4">

            <div class="experience-card">

                <img src="/images/discover/lodh-falls.jpg" alt="Waterfalls">

                <div class="experience-overlay">

                    <h3>🌊 Waterfalls</h3>

                    <a href="/places" class="btn btn-light">

                        Explore

                    </a>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="experience-card">

                <img src="/images/discover/betla.jpg" alt="Wildlife">

                <div class="experience-overlay">

                    <h3>🦁 Wildlife</h3>

                    <a href="/places" class="btn btn-light">

                        Explore

                    </a>

                </div>

            </div>

        </div>

        <div class="col-lg-4">

            <div class="experience-card">

                <img src="/images/discover/patratu.jpg" alt="Adventure">

                <div class="experience-overlay">

                    <h3>🥾 Adventure</h3>

                    <a href="/places" class="btn btn-light">

                        Explore

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>
<div class="container mt-5" id="main">
  <h2 class="section-title text-center mb-4">DISCOVER JHARKHAND</h2>

  <div class="row g-4">

    <!-- 🌊 Lodh Falls -->
    <div class="col-md-4">
      <div class="card tour-card">
        <img
          src="/images/discover/lodh-falls.jpg"
          class="card-img-top"
          alt="Lodh Falls"
          loading="lazy"
        >
        <div class="card-body">
          <h5 class="card-title">Lodh Falls</h5>
          <p class="card-text">
            One of Jharkhand’s tallest and most scenic waterfalls surrounded by dense forest.
          </p>
        </div>
      </div>
    </div>

    <!-- 🌲 Betla National Park -->
    <div class="col-md-4">
      <div class="card tour-card">
        <img
          src="/images/discover/betla.jpg"
          class="card-img-top"
          alt="Betla National Park"
          loading="lazy"
        >
        <div class="card-body">
          <h5 class="card-title">Betla National Park</h5>
          <p class="card-text">
            A wildlife lover’s paradise — explore sal forests, elephants and scenic beauty.
          </p>
        </div>
      </div>
    </div>

    <!-- 🏞️ Patratu Valley -->
    <div class="col-md-4">
      <div class="card tour-card">
        <img
          src="/images/discover/patratu.jpg"
          class="card-img-top"
          alt="Patratu Valley"
          loading="lazy"
        >
        <div class="card-body">
          <h5 class="card-title">Patratu Valley</h5>
          <p class="card-text">
            A breathtaking drive through winding roads with panoramic views of the valley.
          </p>
        </div>
      </div>
    </div>

  </div>
</div>


<!-- 🌤️ What to See -->
<div class="container mt-5">
  <h2 class="section-title text-center mb-4">WHAT TO SEE</h2>

  <div class="row g-4">

    <!-- 🛕 Temples & Heritage -->
    <div class="col-md-3">
      <div class="card tour-card">
        <img src="/images/what-to-see/temple.jpg" class="card-img-top" alt="Temples & Heritage">
        <div class="card-body text-center">
          <h6>Temples & Heritage</h6>
        </div>
      </div>
    </div>

    <!-- 🌲 Nature & Wildlife -->
    <div class="col-md-3">
      <div class="card tour-card">
        <img src="/images/what-to-see/wildlife.jpg" class="card-img-top" alt="Nature & Wildlife">
        <div class="card-body text-center">
          <h6>Nature & Wildlife</h6>
        </div>
      </div>
    </div>

    <!-- 🧗 Adventure & Trekking -->
    <div class="col-md-3">
      <div class="card tour-card">
        <img src="/images/what-to-see/adventure.jpg" class="card-img-top" alt="Adventure & Trekking">
        <div class="card-body text-center">
          <h6>Adventure & Trekking</h6>
        </div>
      </div>
    </div>

    <!-- 🎉 Festivals & Culture -->
    <div class="col-md-3">
      <div class="card tour-card">
        <img src="/images/what-to-see/festival.jpg" class="card-img-top" alt="Festivals & Culture">
        <div class="card-body text-center">
          <h6>Festivals & Culture</h6>
        </div>
      </div>
    </div>

  </div>
</div>


  <!-- 📰 Latest Updates -->
  <div class="container mt-5 mb-5">
    <h2 class="section-title">Latest Updates</h2>
    <div class="list-group">
      <a href="#" class="list-group-item list-group-item-action">📅 Deepotsav 2025 lights up Ranchi and Deoghar with festive fervour - Oct 27, 2025</a>
      <a href="#" class="list-group-item list-group-item-action">🌍 Jharkhand Tourism showcases at ITB Asia 2025 - Oct 18, 2025</a>
      <a href="#" class="list-group-item list-group-item-action">🗺️ Roadmap for Eco Tourism in Jharkhand unveiled - Oct 15, 2025</a>
      <a href="#" class="list-group-item list-group-item-action">🎉 Winter Carnival 2025 announced at Netarhat - Oct 10, 2025</a>
    </div>
  </div>

 <!-- ========================================= -->
