<!-- ========================================= -->
<!-- AI RECOMMENDATION -->
<!-- ========================================= -->

<section class="ai-section">

    <div class="section-heading">

        <span class="section-badge">

            🤖 Artificial Intelligence

        </span>

        <h2>

            AI Travel Advisor

        </h2>

        <p>

            Personalized recommendations generated specifically for your journey.

        </p>

    </div>

    <div class="ai-panel">

        <div class="ai-top">

            <div class="ai-avatar">

                🤖

            </div>

            <div>

                <h3>

                    Smart Travel Recommendation

                </h3>

                <small>

                    Generated by Gemini AI

                </small>

            </div>

        </div>

        <div class="ai-message">

            <% if(typeof aiRecommendation === "string"){ %>

                <p>

                    <%= aiRecommendation %>

                </p>

            <% } else if(aiRecommendation && aiRecommendation.summary){ %>

                <p>

                    <%= aiRecommendation.summary %>

                </p>

            <% } else { %>

                <p>

                    Enjoy a well-balanced journey through Jharkhand while following eco-friendly travel practices and exploring local culture.

                </p>

            <% } %>

        </div>

        <hr>

        <div class="ai-grid">

            <div class="ai-box">

                🌱

                <h4>

                    Eco Advice

                </h4>

                <p>

                    Prefer shared transport and avoid plastic waste.

                </p>

            </div>

            <div class="ai-box">

                💰

                <h4>

                    Budget Advice

                </h4>

                <p>

                    Your itinerary is optimized for maximum value.

                </p>

            </div>

            <div class="ai-box">

                📸

                <h4>

                    Photography

                </h4>

                <p>

                    Sunrise and sunset locations are included.

                </p>

            </div>

            <div class="ai-box">

                ⭐

                <h4>

                    AI Confidence

                </h4>

                <h3>

                    96%

                </h3>

            </div>

        </div>

    </div>

</section>