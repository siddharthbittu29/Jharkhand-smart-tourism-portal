<link rel="stylesheet" href="/css/planner.css">
<div class="container py-5">


    <h1 class="text-success mb-4">
        AI Smart Travel Plan
    </h1>

    <div class="card shadow p-4 mb-4">

        <h4>Trip Summary</h4>

        <p>
            <strong>Destination:</strong>
            <%= destination %>
        </p>

        <p>
            <strong>Days:</strong>
            <%= tripDays %>
        </p>

        <p>
            <strong>Budget:</strong>
            ₹ <%= tripBudget %>
        </p>

        <p>
            <strong>Eco Score:</strong>
            🌱 <%= ecoScore %>/100
        </p>

    </div>

    <h3 class="mb-4">
        Recommended Itinerary
    </h3>

    <div class="row">

        <% itinerary.forEach(item => { %>

        <div class="col-md-4 mb-4">

            <div class="card shadow h-100">

                <img
                    src="<%= item.image %>"
                    class="card-img-top"
                    style="height:220px;object-fit:cover;"
                >

                <div class="card-body">

                    <h5>
                        Day <%= item.day %>
                    </h5>

                    <h4 class="text-success">
                        <%= item.place %>
                    </h4>

                    <p>
                        Estimated Cost:
                        ₹ <%= item.cost %>
                    </p>

                </div>

            </div>

        </div>

        <% }) %>

    </div>

    <!-- HOTEL RECOMMENDATIONS -->

<div class="card shadow p-4 mb-4">

    <h3 class="text-primary mb-4">
        🏨 Recommended Hotels
    </h3>

    <div class="row">

        <% hotelRecommendations.forEach(rec => { %>

            <% if(rec.hotel){ %>

                <div class="col-md-4 mb-4">

                    <div class="card h-100 shadow-sm">

                        <img
                            src="<%= rec.hotel.image %>"
                            class="card-img-top"
                            style="height:220px;object-fit:cover;"
                        >

                        <div class="card-body">

                            <h5>
                                <%= rec.hotel.name %>
                            </h5>

                            <p class="text-muted">
                                <%= rec.hotel.district %>
                            </p>

                            <p>
                                ⭐ <%= rec.hotel.rating %>
                            </p>

                            <p>
                                Starting From
                                ₹<%= rec.hotel.price_from %>
                            </p>

                            <p>
                                <%= rec.hotel.availability %>
                            </p>

                            <a
                                href="<%= rec.hotel.map %>"
                                target="_blank"
                                class="btn btn-success"
                            >
                                View Location
                            </a>

                        </div>

                    </div>

                </div>

            <% } %>

        <% }) %>

    </div>

<div class="card shadow-lg border-0 mt-5">

    <div class="card-header bg-success text-white text-center py-3">
        <h2 class="mb-0">
            💰 AI Cost Analysis Report
        </h2>
    </div>

    <div class="card-body p-4">

        <div class="row text-center g-4">

            <div class="col-md-3">
                <div class="card border-primary h-100">
                    <div class="card-body">
                        <h5>🏨 Hotel Cost</h5>
                        <h3 class="text-primary">
                            ₹ <%= hotelCost %>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-warning h-100">
                    <div class="card-body">
                        <h5>🍽 Food Cost</h5>
                        <h3 class="text-warning">
                            ₹ <%= foodCost %>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-info h-100">
                    <div class="card-body">
                        <h5>🚗 Transport</h5>
                        <h3 class="text-info">
                            ₹ <%= transportCost %>
                        </h3>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card border-success h-100">
                    <div class="card-body">
                        <h5>💵 Total Cost</h5>
                        <h3 class="text-success">
                            ₹ <%= totalCost %>
                        </h3>
                    </div>
                </div>
            </div>

        </div>

        <hr class="my-4">

        <div class="text-center">

            <h3 class="<%= budgetStatus.includes('Within') ? 'text-success' : 'text-danger' %>">

                <%= budgetStatus %>

            </h3>

            <p class="text-muted">
                Budget Provided: ₹ <%= tripBudget %>
            </p>

        </div>

    </div>

</div>    
<div class="card shadow p-4 mt-4">

        <h4>
            Travel Tips
        </h4>

        <ul>
            <li>Carry water bottles.</li>
            <li>Book hotels in advance.</li>
            <li>Best season: October to February.</li>
            <li>Respect local culture and nature.</li>
        </ul>

    </div>

    <a
        href="/"
        class="btn btn-success mt-4"
    >
        Back To Home
    </a>

</div>