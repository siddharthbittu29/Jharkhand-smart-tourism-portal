<section class="container py-4">
  <h1 class="mb-3">Book Hotels</h1>
  <p class="text-muted">Find and book government-run and partner hotels across Jharkhand.</p>

  <form class="row g-3 my-3"  >
    <div class="col-md-4">
      <label class="form-label">Destination</label>
      <input class="form-control" placeholder="e.g., Ranchi, Netarhat">
    </div>
    <div class="col-md-3">
      <label class="form-label">Check-in</label>
      <input type="date" class="form-control">
    </div>
    <div class="col-md-3">
      <label class="form-label">Check-out</label>
      <input type="date" class="form-control">
    </div>
    <div class="col-md-2 d-flex align-items-end">
      <button class="btn btn-success w-100">Search</button>
    </div>
  </form>

  <div class="alert alert-info">Sample page: wire this to your real listings later.</div>
</section>


