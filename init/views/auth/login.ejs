<div class="brand text-center mb-4">
  <img
    src="/images/jharkhand_tourism_logo_final.png"
    alt="Jharkhand Tourism"
    style="height:90px;"
  >

  <h2 class="mt-3 fw-bold text-success">
    Welcome Back
  </h2>

  <p class="text-muted">
    Login to continue your tourism journey
  </p>
</div>

<form method="POST" action="/auth/login">

  <div class="mb-3">
    <label class="form-label">Email Address</label>
    <input
      type="email"
      name="email"
      class="form-control"
      required
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Password</label>
    <input
      type="password"
      name="password"
      class="form-control"
      required
    >
  </div>

  <button
    type="submit"
    class="btn btn-tourism w-100"
  >
    Login
  </button>

</form>

<div class="text-center mt-4">

  Don't have an account?

  <a href="/auth/register">
    Create Account
  </a>

</div>