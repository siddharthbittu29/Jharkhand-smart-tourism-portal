<div class="brand text-center mb-4">
  <img
    src="/images/jharkhand_tourism_logo_final.png"
    alt="Jharkhand Tourism"
    style="height:90px;"
  >

  <h2 class="mt-3 fw-bold text-success">
    Create Tourist Account
  </h2>

  <p class="text-muted">
    Join Jharkhand Smart Tourism Platform
  </p>
</div>

<form method="POST" action="/auth/register">

  <div class="mb-3">
    <label class="form-label">Full Name</label>
    <input
      type="text"
      name="name"
      class="form-control"
      required
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Email Address</label>
    <input
      type="email"
      name="email"
      class="form-control"
      required
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Password</label>
    <input
      type="password"
      name="password"
      class="form-control"
      minlength="6"
      required
    >
  </div>

  <button
    type="submit"
    class="btn btn-tourism w-100"
  >
    Create Account
  </button>

</form>

<div class="text-center mt-4">

  Already have an account?

  <a href="/auth/login">
    Login
  </a>

</div>