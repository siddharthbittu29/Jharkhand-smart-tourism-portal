<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title><%= place.name %> — Explore Jharkhand</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="stylesheet" href="/css/places.css">
</head>
<body>
<main class="container single">
  <a href="/places" class="back">&larr; Back to list</a>

  <header class="single-hero">
  <img class="single-hero-img" src="<%= place.image %>" alt="<%= place.name %>">

    <div class="single-hero-inner">
      <h1><%= place.name %></h1>
      <p class="muted"><span class="badge"><%= place.category %></span> • <%= place.district %></p>
    </div>
  </header>

  <section class="single-content">
    <div class="left">
      <h2>About</h2>
      <p><%= place.long_desc || place.short_desc %></p>

      <div class="buttons">
        <a class="btn primary" href="<%= place.google_map %>" target="_blank">Plan Visit</a>
        <button class="btn ghost bookmark" data-id="<%= place.place_id %>">Bookmark</button>
        <button class="btn" id="shareBtn">Share</button>
      </div>

      <h3>Location</h3>
      <div class="map">
        <iframe src="<%= place.google_map %>&output=embed" width="100%" height="360" style="border:0" allowfullscreen loading="lazy"></iframe>
      </div>
    </div>

    <aside class="right">
      <div class="card glass">
        <h4>Quick Info</h4>
        <ul>
          <li><strong>Category:</strong> <%= place.category %></li>
          <li><strong>District:</strong> <%= place.district %></li>
          <li><strong>ID:</strong> <%= place.place_id %></li>
        </ul>
      </div>

      <div class="card glass">
        <h4>Nearby</h4>
        <% if (!nearby || nearby.length === 0) { %>
          <p>No nearby suggestions.</p>
        <% } else { %>
          <ul>
            <% nearby.forEach(n => { %>
              <li><a href="/places/<%= n.place_id %>"><%= n.name %></a> <small class="muted">• <%= n.district %></small></li>
            <% }) %>
          </ul>
        <% } %>
      </div>
    </aside>
  </section>
</main>

<script src="/js/places.js" defer></script>
<script>
  document.getElementById('shareBtn')?.addEventListener('click', async ()=>{
    const url = location.href;
    if (navigator.share) {
      navigator.share({title: document.title, url});
    } else {
      try { await navigator.clipboard.writeText(url); alert('Link copied'); } catch(e){ prompt('Copy this URL', url) }
    }
  });
</script>
<!--  -->
<section class="nearby-hotels">
  <h3>Nearby Hotels</h3>
  <% if (nearbyHotels && nearbyHotels.length) { %>
    <div class="hotels-row">
      <% nearbyHotels.forEach(h => { %>
        <div class="hotel-summary">
          <a href="/hotels/<%= h.id %>">
            <img src="<%= h.image %>" alt="<%= h.name %>">
            <div><strong><%= h.name %></strong></div>
            <div class="muted">From ₹<%= h.price_from %></div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="muted">No nearby hotels found.</p>
  <% } %>
</section>


</body>
</html>
