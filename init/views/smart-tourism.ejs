<!-- init/views/smart/tourism.ejs -->
<div class="container">
  <h1 class="mb-3">Smart Tourism – Jharkhand</h1>
  <p class="lead">A smart digital platform to promote Eco & Cultural Tourism in Jharkhand.</p>

  <div class="row g-4 mt-2">
    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Problem Overview</h5>
          <ul class="mb-0">
            <li>Tourism data is fragmented/outdated.</li>
            <li>Limited visibility of eco & cultural sites.</li>
            <li>Language & accessibility barriers.</li>
            <li>Low digital benefit to local communities.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title">Proposed Solution</h5>
          <ul class="mb-0">
            <li>Web & mobile platform with interactive map.</li>
            <li>AI itinerary planner & eco insights.</li>
            <li>Festivals & cultural storytelling hub.</li>
            <li>Integration with booking & local stakeholders.</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title">Core Modules</h5>
          <div class="row row-cols-2 row-cols-md-3 g-3">
            <div class="col"><span>🏞️ Explore Destinations</span></div>
            <div class="col"><span>🎭 Cultural Hub</span></div>
            <div class="col"><span>♻️ Eco Insights</span></div>
            <div class="col"><span>🧭 Smart Trip Planner</span></div>
            <div class="col"><span>🧑‍🤝‍🧑 Local Connect</span></div>
            <div class="col"><span>📸 Virtual Experiences</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
