<div class="card shadow-soft h-100 card-hover">
  <div class="card-img-wrap">
    <img src="<%= hotel.image %>" class="card-img-top" alt="<%= hotel.name %>">
    <% if (hotel.badge) { %>
      <span class="badge badge-float"><%= hotel.badge %></span>
    <% } %>
  </div>
  <div class="card-body d-flex flex-column">
    <h5 class="card-title mb-1"><%= hotel.name %></h5>
    <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i><%= hotel.city %></p>
    <p class="card-text flex-grow-1"><%= hotel.desc %></p>
    <div class="d-flex align-items-center justify-content-between mt-2">
      <div class="rating" aria-label="rating">
        <% for (let i=1;i<=5;i++){ %>
          <i class="fa-star <%= i <= hotel.stars ? 'fa-solid' : 'fa-regular' %>"></i>
        <% } %>
      </div>
      <div class="price">
        <span class="fw-semibold">₹<%= hotel.price.toLocaleString('en-IN') %></span><span class="text-muted small">/night</span>
      </div>
    </div>
    <a href="/book?hotel=<%= encodeURIComponent(hotel.slug) %>" class="btn btn-success-soft mt-3 w-100">
      <i class="fa-solid fa-calendar-check me-2"></i>Book Now
    </a>
  </div>
</div>

