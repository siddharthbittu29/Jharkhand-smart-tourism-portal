<div class="card shadow-soft h-100 card-hover">
  <div class="card-img-wrap">
    <img src="<%= fest.image %>" class="card-img-top" alt="<%= fest.name %>">
    <% if (fest.month) { %><span class="badge badge-float"><%= fest.month %></span><% } %>
  </div>
  <div class="card-body d-flex flex-column">
    <h5 class="card-title mb-1"><%= fest.name %></h5>
    <p class="text-muted small mb-2"><i class="fa-solid fa-location-dot me-1"></i><%= fest.region %></p>
    <p class="card-text flex-grow-1"><%= fest.desc %></p>
    <a href="/festivals/<%= fest.slug %>" class="btn btn-outline-success mt-2 w-100">
      <i class="fa-solid fa-circle-info me-2"></i>Know More
    </a>
  </div>
</div>
