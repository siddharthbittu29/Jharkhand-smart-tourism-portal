<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= typeof title !== 'undefined' ? title : 'Authentication' %></title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body{
      min-height:100vh;
      display:flex;
      justify-content:center;
      align-items:center;
      background:linear-gradient(
        135deg,
        #0f4c3a,
        #1b5e20,
        #2e7d32
      );
      font-family:Segoe UI,sans-serif;
    }

    .auth-card{
      width:100%;
      max-width:500px;
      background:#fff;
      padding:40px;
      border-radius:20px;
      box-shadow:0 15px 40px rgba(0,0,0,.15);
    }

    .brand{
      text-align:center;
      margin-bottom:25px;
    }

    .brand img{
      height:80px;
    }

    .brand h2{
      margin-top:10px;
      font-weight:700;
      color:#1b5e20;
    }

    .btn-tourism{
      background:#1b5e20;
      color:white;
      border:none;
    }

    .btn-tourism:hover{
      background:#134518;
      color:white;
    }
  </style>
</head>

<body>

<div class="auth-card">
  <%- body %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>