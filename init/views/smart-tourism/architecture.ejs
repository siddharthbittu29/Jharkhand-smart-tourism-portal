<%- include('./partials/nav') %>

<section class="py-4">
  <div class="container">
    <h1 class="display-6 fw-semibold mb-3">Implementation Architecture + System Flow</h1>
    <p class="text-muted mb-4">
      High-level view of modules, data flow, and integrations for the Smart Tourism platform.
    </p>

    <!-- Architecture blocks -->
    <div class="row g-4">
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Frontend (Web + Mobile)</h5>
            <ul class="mb-0 small text-muted">
              <li>Public site (EJS / React option ready)</li>
              <li>Search, filters, itinerary, bookings</li>
              <li>Accessibility, i18n (EN/HI)</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Backend API (Express)</h5>
            <ul class="mb-0 small text-muted">
              <li>Auth (JWT), rate limits</li>
              <li>Bookings, passes, reviews</li>
              <li>Partner onboarding & KYC</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Data Layer</h5>
            <ul class="mb-0 small text-muted">
              <li>PostgreSQL (core records)</li>
              <li>Redis (sessions, cache)</li>
              <li>Object storage (images/UGC)</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Integrations</h5>
            <ul class="mb-0 small text-muted">
              <li>Payments (UPI/cards)</li>
              <li>SMS/Email/WhatsApp alerts</li>
              <li>Maps & Weather APIs</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Admin Console</h5>
            <ul class="mb-0 small text-muted">
              <li>Content management</li>
              <li>Inventory & pricing</li>
              <li>Dashboards & reports</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="fw-semibold mb-2">Security & Ops</h5>
            <ul class="mb-0 small text-muted">
              <li>HTTPS, CSP, audit logs</li>
              <li>Backups & monitoring</li>
              <li>CI/CD & env configs</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- System Flow -->
    <div class="card shadow-sm mt-4">
      <div class="card-body">
        <h3 class="h6 fw-semibold mb-3">System Flow (Happy Path)</h3>
        <ol class="small text-muted mb-0">
          <li>User browses destinations → selects experience</li>
          <li>Checks availability → price quoted from API</li>
          <li>Authenticates (OTP/JWT) → pays via gateway</li>
          <li>Booking stored in DB → e-ticket/QR generated</li>
          <li>At site: QR validated → access granted</li>
          <li>Post-trip: rating & review → dashboard updated</li>
        </ol>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/scripts') %>








<!-- L1: High-level blocks -->
    <div class="row g-3">
      <div class="col-md-6 col-lg-3">
        <div class="arch-card h-100">
          <div class="arch-title">Channel Layer</div>
          <ul class="mb-0 small">
            <li>Web (Next.js / SSR)</li>
            <li>Mobile (PWA)</li>
            <li>Kiosk & QR Trails</li>
            <li>Admin Console</li>
          </ul>
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="arch-card h-100">
          <div class="arch-title">API Gateway</div>
          <ul class="mb-0 small">
            <li>Auth & Rate Limit</li>
            <li>Routing / BFF</li>
            <li>Observability</li>
            <li>Versioning</li>
          </ul>
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="arch-card h-100">
          <div class="arch-title">Services</div>
          <ul class="mb-0 small">
            <li>Catalog (Places/Events)</li>
            <li>Booking & Payments</li>
            <li>User/Reviews/UGC</li>
            <li>Alerts & SOS</li>
          </ul>
        </div>
      </div>

      <div class="col-md-6 col-lg-3">
        <div class="arch-card h-100">
          <div class="arch-title">Data Layer</div>
          <ul class="mb-0 small">
            <li>Postgres (OLTP)</li>
            <li>Redis (Cache)</li>
            <li>Blob (Images/Docs)</li>
            <li>Warehouse + BI</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- L2: System Flow -->
    <h2 class="h5 fw-semibold mt-4 mb-2">System Flow (Request Lifecycle)</h2>
    <div class="flow">
      <div class="flow-step">User</div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">Web / PWA</div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">API Gateway</div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">Service (e.g., Booking)</div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">DB / Cache / Files</div>
      <div class="flow-arrow">→</div>
      <div class="flow-step">Events → Analytics</div>
    </div>

    <!-- Non-functional -->
    <div class="row g-3 mt-1">
      <div class="col-lg-6">
        <div class="arch-card h-100">
          <div class="arch-title">Security & Compliance</div>
          <ul class="small mb-0">
            <li>OAuth / SSO, role-based access (citizen, partner, admin)</li>
            <li>Input validation, content moderation, audit logs</li>
            <li>Backups, encryption at rest & in transit</li>
          </ul>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="arch-card h-100">
          <div class="arch-title">Ops & Observability</div>
          <ul class="small mb-0">
            <li>Central logging, metrics, tracing</li>
            <li>Blue/green deployments, rollbacks</li>
            <li>Autoscaling & CDN caching for media</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- CTA Navigation -->
    <div class="text-center mt-4">
      <a href="/smart-tourism/journey" class="btn btn-outline-primary me-2">← Back to Slide 5</a>
      <a href="/smart-tourism/architecture" class="btn btn-primary">Current Slide ✓</a>
    </div>
  </div>
</section>

<%- include('../partials/scripts') %>

<style>
  .arch-card{
    border:1px solid #e5e7eb;border-radius:14px;background:#fff;padding:1rem 1rem;
    box-shadow:0 2px 10px rgba(0,0,0,.05)
  }
  .arch-title{font-weight:700;margin-bottom:.5rem}
  .flow{
    display:flex;flex-wrap:wrap;gap:.5rem;align-items:center;
    background:#f8fafc;border:1px solid #e5e7eb;border-radius:14px;padding:12px 14px
  }
  .flow-step{
    padding:.4rem .7rem;border-radius:10px;border:1px solid #dbe3ef;background:#fff;font-weight:600
  }
  .flow-arrow{font-size:1.25rem;opacity:.7}
</style>


