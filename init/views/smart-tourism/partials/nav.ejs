<%
// Tabs config
const base = '/smart-tourism';
const tabs = [
  { href: `${base}`,             text: 'Overview' },
  { href: `${base}/objectives`,  text: 'Objectives' },
  { href: `${base}/features`,    text: 'Features' },
  { href: `${base}/journey`,     text: 'User Journey' },
  { href: `${base}/architecture`,text: 'Architecture' },
  { href: `${base}/core-features`, text: 'Core Features' }  // ✅ SLIDE 7 ADDED HERE
  ];
%>

<div class="container pt-3">
  <ul class="nav gap-2 smart-tabs">
    <% tabs.forEach(t => { 
         const active = (currentPath === t.href) ? 'active' : ''; %>
      <li class="nav-item">
        <a class="btn btn-outline-secondary <%= active %>" href="<%= t.href %>"><%= t.text %></a>
      </li>
    <% }) %>
  </ul>
</div>

<style>
 :root{
  --clr-deep:#1B4332;--clr-green:#2D6A4F;--clr-mint:#95D5B2;--clr-beige:#F5EDD8;--clr-beige-2:#EFE7CF;--clr-ink:#0B1D16;--clr-white:#fff;
  --radius:16px;--shadow-sm:0 6px 16px rgb(0 0 0 / 12%);--shadow-lg:0 24px 48px rgb(0 0 0 / 20%);
  --transition:280ms cubic-bezier(.2,.8,.2,1)
}
*{box-sizing:border-box}
body{background:var(--clr-beige);color:var(--clr-ink);font-family:Poppins,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial}
.frame-16x9{aspect-ratio:16/9;position:relative;width:min(1200px,96vw);margin:2rem auto;border-radius:20px;overflow:hidden;background:linear-gradient(180deg, rgb(0 0 0 / 25%), rgb(0 0 0 / 25%));box-shadow:var(--shadow-lg)}
.bg-photo{position:absolute;inset:0;background:url("/smart/images/netarhat.jpg") center/cover no-repeat fixed;filter:saturate(.9) contrast(1.1) brightness(.85);transform:translateZ(0)}
.overlay{position:absolute;inset:0;background:linear-gradient(180deg, rgb(17 35 28 / 65%), rgb(17 35 28 / 35%)), radial-gradient(1200px 600px at 80% 0%, rgb(149 213 178 / 15%), transparent 60%)}
@media (prefers-reduced-motion:no-preference){.frame-16x9:hover .bg-photo{transform:scale(1.03);transition:transform var(--transition)}}
.slide-header{position:relative;z-index:2;padding:clamp(20px,3.5vw,36px);color:var(--clr-white);text-shadow:0 2px 10px rgb(0 0 0 / 50%)}
.slide-header h1{margin:0 0 .25rem;font-weight:700;letter-spacing:.2px;font-size:clamp(28px,3.2vw,40px)}
.caption{margin:0;font-size:clamp(14px,1.6vw,16px);opacity:.95}
.feature-grid{position:relative;z-index:2;display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(12px,2vw,18px);padding:0 clamp(16px,3vw,28px) clamp(16px,3vw,28px)}
@media (max-width:980px){.frame-16x9{aspect-ratio:auto;height:auto}.feature-grid{grid-template-columns:repeat(2,1fr)}}
@media (max-width:640px){.feature-grid{grid-template-columns:1fr}}
.card{background:linear-gradient(180deg, rgb(255 255 255 / 88%), rgb(255 255 255 / 92%));border:1px solid rgb(27 67 50 / 12%);border-radius:var(--radius);overflow:clip;box-shadow:var(--shadow-sm);display:flex;flex-direction:column}
.card-trigger{all:unset;cursor:pointer;display:grid;grid-template-columns:56px 1fr auto;align-items:center;gap:14px;padding:16px}
.card-trigger:focus-visible{outline:3px solid var(--clr-mint);outline-offset:2px;border-radius:calc(var(--radius) - 2px)}
.icon{width:44px;height:44px;filter:drop-shadow(0 2px 3px rgb(0 0 0 / 12%))}
.card-text h2{margin:0 0 4px;font-size:18px;color:var(--clr-deep)}
.card-text p{margin:0;color:#2a2a2a;font-size:14px}
.card:hover{transform:translateY(-2px);box-shadow:0 10px 22px rgb(0 0 0 / 16%);transition:transform var(--transition),box-shadow var(--transition)}
.micro-anim{width:20px;height:20px;border-radius:50%;background:radial-gradient(circle at 30% 30%, var(--clr-mint), var(--clr-green));opacity:.75;transform:translateZ(0) scale(1)}
@media (prefers-reduced-motion:no-preference){.card:hover .micro-anim{animation:floaty 1.6s ease-in-out infinite alternate}}
@keyframes floaty{from{transform:translateY(-2px) scale(1);filter:brightness(1)}to{transform:translateY(3px) scale(1.08);filter:brightness(1.15)}}
.card-panel{display:none;border-top:1px solid rgb(27 67 50 / 12%);background:linear-gradient(180deg, var(--clr-beige-2), #fff)}
.card.expanded .card-panel{display:block}
.demo{padding:14px 16px 18px}
.btn{appearance:none;border:none;cursor:pointer;background:var(--clr-green);color:#fff;font-weight:600;padding:10px 14px;border-radius:12px;box-shadow:0 6px 14px rgb(45 106 79 / 25%)}
.btn:hover{background:#276047}
.btn:focus-visible{outline:3px solid var(--clr-mint);outline-offset:2px}
.btn.icon{width:40px;height:40px;padding:0;border-radius:12px;font-size:20px}
.input,.select{width:100%;max-width:420px;padding:10px 12px;border-radius:12px;border:1px solid rgb(27 67 50 / 24%);background:#fff}
.label{display:block;margin-bottom:6px;font-weight:600;color:var(--clr-deep)}
.list{margin:8px 0 0;padding-left:16px}
.itinerary{margin:0 0 10px;padding-left:18px}
.itinerary li{margin:6px 0}
.map-shell{position:relative;border-radius:14px;overflow:hidden;border:1px solid rgb(27 67 50 / 20%);background:#e8efe9;height:220px}
.map-viewport{width:100%;height:100%;transform-origin:center center;background:linear-gradient(90deg, rgb(255 255 255 / 30%), transparent)}
.tile-grid{position:absolute;inset:0;background-image:linear-gradient(#cfded4 1px, transparent 1px),linear-gradient(90deg, #cfded4 1px, transparent 1px);background-size:40px 40px,40px 40px;opacity:.8}
.map-pin{position:absolute;width:12px;height:12px;border-radius:50%;background:var(--clr-deep);box-shadow:0 0 0 4px rgb(149 213 178 / 55%)}
.meter{width:100%;max-width:520px;height:16px;border-radius:999px;overflow:hidden;background:linear-gradient(180deg,#e7efe8,#d8e7da);border:1px solid rgb(27 67 50 / 20%)}
.meter-fill{height:100%;background:linear-gradient(90deg,var(--clr-mint),var(--clr-green));width:0%}
@media (prefers-reduced-motion:no-preference){.meter-fill{transition:width 900ms ease}}
.eco-readout{margin:8px 0;font-weight:700;color:var(--clr-deep)}
.arvr-shell{position:relative;max-width:560px;border-radius:14px;overflow:hidden;border:1px solid rgb(27 67 50 / 20%)}
.arvr-base,.arvr-overlay{display:block;width:100%;height:auto;object-fit:cover}
.arvr-overlay{position:absolute;inset:0;clip-path:inset(0 50% 0 0);pointer-events:none}
.range{width:100%;margin-top:10px}
.hint{margin:6px 0 0;font-size:12px;color:#345;opacity:.9}
@media (prefers-reduced-motion:reduce){
  .frame-16x9:hover .bg-photo,.card:hover{transform:none!important}
  .micro-anim,.meter-fill{animation:none!important;transition:none!important}
}

</style>





